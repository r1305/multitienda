NODE_ENV=production
APP_PORT=3001
APP_URL=https://tudominio.com
CORS_ORIGIN=https://tudominio.com

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_POOL_MAX=5
DB_POOL_MIN=0

JWT_SECRET=your-random-secret-key-here
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-here

# Redis (optional — only if Redis is installed on the server)
# REDIS_URL=redis://127.0.0.1:6379
# SESSION_STORE=redis

# cPanel without Redis (recommended):
SESSION_STORE=memory

GOOGLE_MAPS_API_KEY=
FIREBASE_CREDENTIALS=./firebase-credentials.json
FIREBASE_VAPID_KEY=

# Performance tuning
BODY_LIMIT=2mb
SERVE_STATIC=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
CACHE_SETTINGS_TTL=300
CACHE_RESTAURANTS_TTL=120
CACHE_ADMIN_SETTINGS_TTL=300
GPS_MIN_INTERVAL_MS=30000
GPS_MIN_DISTANCE_KM=0.05
DELIVERY_ORDERS_LIMIT=50

# PM2: disable in-cluster notification processing (use worker app)
ENABLE_NOTIFICATION_WORKER=true
