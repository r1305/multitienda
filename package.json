{
  "name": "multitienda-node",
  "version": "1.1.1",
  "description": "Multitienda backend - Node.js",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "start:worker": "node workers/notificationWorker.js",
    "start:pm2": "pm2 start ecosystem.config.js",
