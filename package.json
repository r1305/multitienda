    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^7.1.1",
    "connect-session-sequelize": "7.1.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^5.0.2",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "hashids": "^2.3.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
