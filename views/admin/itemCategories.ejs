<% var active = 'itemcategories'; var pageTitle = 'Menu Categories'; %>
<% var scripts = ''; %>
<%
var body = `
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>All Categories (${typeof count !== 'undefined' ? count : 0})</span>
        <span class="text-muted" style="font-size:12px"><i class="fas fa-info-circle"></i> Categorias se gestionan desde el panel del Store Owner</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>ID</th><th>Name</th><th>Tienda</th><th>Items</th><th>Status</th></tr></thead>
            <tbody>`;

if (typeof categories !== 'undefined' && categories.length) {
  categories.forEach(function(c) {
    body += `<tr>
      <td>${c.id}</td>
      <td><strong>${c.name}</strong></td>
      <td><small>${c.restaurant_name || 'Global'}</small></td>
      <td>${c.items_count || 0}</td>
      <td><span class="badge badge-${c.is_enabled ? 'success' : 'danger'}">${c.is_enabled ? 'Active' : 'Disabled'}</span></td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="5" class="text-center text-muted py-4">No categories found</td></tr>';
}

body += `</tbody></table></div></div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
