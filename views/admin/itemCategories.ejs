<% var active = 'itemcategories'; var pageTitle = 'Menu Categories'; %>
<% var scripts = ''; %>
<%
var body = `
<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Add New Category</div>
            <div class="card-body">
                <form method="POST" action="/admin/item-category/new/save">
                    <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" required></div>
                    <button type="submit" class="btn btn-primary btn-block">Create</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">All Categories (${typeof count !== 'undefined' ? count : 0})</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead><tr><th>ID</th><th>Name</th><th>Items</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody>`;

if (typeof categories !== 'undefined' && categories.length) {
  categories.forEach(function(c) {
    body += `<tr>
      <td>${c.id}</td>
      <td><strong>${c.name}</strong></td>
      <td>${c.items_count || 0}</td>
      <td><span class="badge badge-${c.is_enabled ? 'success' : 'danger'}">${c.is_enabled ? 'Active' : 'Disabled'}</span></td>
      <td>
        <a href="/admin/item-category/disable/${c.id}" class="btn btn-sm btn-outline-warning"><i class="fas fa-ban"></i></a>
        <button class="btn btn-sm btn-outline-primary" data-toggle="modal" data-target="#editCat${c.id}"><i class="fas fa-edit"></i></button>
      </td>
    </tr>
    <div class="modal fade" id="editCat${c.id}" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
      <form method="POST" action="/admin/item-category/edit/save">
        <input type="hidden" name="id" value="${c.id}">
        <div class="modal-header"><h5>Edit Category</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
        <div class="modal-body"><div class="form-group"><label>Name</label><input type="text" name="name" class="form-control" value="${c.name}" required></div></div>
        <div class="modal-footer"><button type="submit" class="btn btn-primary">Save</button></div>
      </form>
    </div></div></div>`;
  });
} else {
  body += '<tr><td colspan="5" class="text-center text-muted py-4">No categories found</td></tr>';
}

body += `</tbody></table></div></div></div></div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
