<% var active = 'storeowners'; var pageTitle = 'Manage Stores - ' + (typeof owner !== 'undefined' && owner ? owner.name : ''); %>
<% var scripts = ''; %>
<%
var body = '';
if (typeof owner !== 'undefined' && owner) {
  var checkboxes = '';
  if (typeof allStores !== 'undefined') {
    allStores.forEach(function(s) {
      var checked = (typeof assignedIds !== 'undefined' && assignedIds.includes(s.id)) ? 'checked' : '';
      checkboxes += `<div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="stores" value="${s.id}" ${checked}><label class="form-check-label">${s.name}</label></div>`;
    });
  }
  if (!checkboxes) checkboxes = '<p class="text-muted">No stores available. Create a store first.</p>';

  body = `
  <div class="card">
    <div class="card-header">Assign Stores to <strong>${owner.name}</strong> (${owner.email || ''})</div>
    <div class="card-body">
      <form method="POST" action="/admin/store-owner/${owner.id}/stores/save">
        ${checkboxes}
        <hr>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
        <a href="/admin/store-owners" class="btn btn-secondary ml-2">Back</a>
      </form>
    </div>
  </div>`;
}
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
