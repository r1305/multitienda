<% var active = 'delivery'; var pageTitle = 'Delivery Guys'; %>
<% var mc = typeof mapCenter !== 'undefined' ? mapCenter : { lat: 9.9281, lng: -84.0907 }; %>
<% var scripts = `
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
$(function(){
  wireAdminTableSearchSimple("#deliveryTableSearch", "#deliveryTable");

  var mapEl = document.getElementById("deliveryGuysMap");
  if (!mapEl || typeof L === "undefined") return;

  var defaultCenter = [${mc.lat}, ${mc.lng}];
  var map = L.map("deliveryGuysMap", { scrollWheelZoom: true }).setView(defaultCenter, 12);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    maxZoom: 19,
    attribution: "&copy; OpenStreetMap"
  }).addTo(map);

  var markers = {};
  var pollMs = 15000;
  var staleMs = 5 * 60 * 1000;
  var userMovedMap = false;
  map.on("dragstart zoomstart", function() { userMovedMap = true; });

  function esc(s) {
    if (!s) return "";
    return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function markerColor(driver) {
    if (driver.is_active === 0) return "#6c757d";
    if (driver.updated_at && (Date.now() - driver.updated_at) > staleMs) return "#fd7e14";
    return driver.live ? "#28a745" : "#17a2b8";
  }

  function formatUpdated(ts) {
    if (!ts) return "Sin hora de actualizaci\u00f3n";
    var d = new Date(ts);
    if (isNaN(d.getTime())) return "Sin hora de actualizaci\u00f3n";
    return d.toLocaleString();
  }

  function refreshMap() {
    var statusEl = document.getElementById("deliveryMapStatus");
    fetch("/admin/api/delivery-guys-locations", { credentials: "same-origin", headers: { Accept: "application/json" } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var drivers = data.drivers || [];
        var seen = {};
        drivers.forEach(function(d) {
          seen[d.id] = true;
          var pos = [d.lat, d.lng];
          var popup = "<strong>" + esc(d.name) + "</strong><br>" +
            (d.phone ? esc(d.phone) + "<br>" : "") +
            (d.vehicle ? "Veh\u00edculo: " + esc(d.vehicle) + "<br>" : "") +
            "<small>" + formatUpdated(d.updated_at) + (d.live ? " (en vivo)" : "") + "</small>";
          var color = markerColor(d);
          if (markers[d.id]) {
            markers[d.id].setLatLng(pos);
            markers[d.id].setPopupContent(popup);
            markers[d.id].setStyle({ fillColor: color, color: color });
          } else {
            markers[d.id] = L.circleMarker(pos, {
              radius: 9,
              fillColor: color,
              color: color,
              weight: 2,
              opacity: 1,
              fillOpacity: 0.85
            }).addTo(map).bindPopup(popup);
          }
        });
        Object.keys(markers).forEach(function(id) {
          if (!seen[id]) {
            map.removeLayer(markers[id]);
            delete markers[id];
          }
        });
        if (drivers.length && !userMovedMap) {
          var bounds = L.latLngBounds(drivers.map(function(d) { return [d.lat, d.lng]; }));
          if (drivers.length === 1) map.setView(bounds.getCenter(), 14);
          else map.fitBounds(bounds.pad(0.15));
        }
        if (statusEl) {
          statusEl.textContent = drivers.length + " en mapa / " + (data.total || 0) + " repartidores \u00b7 actualizado " + new Date().toLocaleTimeString();
        }
      })
      .catch(function() {
        if (statusEl) statusEl.textContent = "No se pudo cargar ubicaciones";
      });
  }

  refreshMap();
  setInterval(refreshMap, pollMs);
  setTimeout(function() { map.invalidateSize(); }, 300);
});
</script>`; %>
<%
var escHtml = function(s) {
  if (s == null || s === '') return '';
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
};
var modalsHtml = '';
var body = `
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap" style="gap:8px">
        <span><i class="fas fa-map-marked-alt text-primary"></i> Ubicaci\u00f3n en tiempo real</span>
        <div class="d-flex align-items-center flex-wrap" style="gap:12px;font-size:12px">
            <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#28a745"></span> Activo (vivo)</span>
            <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#17a2b8"></span> Activo</span>
            <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#fd7e14"></span> Desactualizado</span>
            <span><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#6c757d"></span> Pendiente</span>
            <small class="text-muted" id="deliveryMapStatus">Cargando mapa...</small>
        </div>
    </div>
    <div class="card-body p-0">
        <div id="deliveryGuysMap" style="height:280px;min-height:200px;background:#e9ecef"></div>
    </div>
</div>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap" style="gap:10px">
        <span>Repartidores</span>
        <div class="admin-list-search ml-auto"><i class="fas fa-search"></i><input type="search" id="deliveryTableSearch" class="form-control form-control-sm" placeholder="Buscar nombre, teléfono, vehículo..." autocomplete="off"></div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
        <table class="table table-hover" id="deliveryTable">
            <thead><tr><th>ID</th><th>Name</th><th>Phone</th><th>Vehicle</th><th>Commission</th><th>Ganancias</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>`;

if (typeof deliveryGuys !== 'undefined' && deliveryGuys.length) {
  deliveryGuys.forEach(function(dg) {
    var statusBadge = dg.is_active !== 0 ? '<span class="badge badge-success">Activo</span>' : '<span class="badge badge-warning">Pendiente</span>';
    var approveBtn = dg.is_active === 0 ? `<a href="/admin/user/approve/${dg.id}" class="btn btn-sm btn-outline-success" title="Aprobar"><i class="fas fa-check"></i></a>` : '';
    var currSymbol = typeof currency !== 'undefined' ? currency : '$';
    var commType = dg.commission_type === 'percentage' ? dg.commission_rate + '%' : dg.commission_type === 'dynamic' ? 'Base ' + currSymbol + (dg.dynamic_base_price || '0') + ' + ' + currSymbol + (dg.dynamic_price_per_km || '0') + '/km' : currSymbol + (dg.fixed_commission || '0.00');
    var commLabel = dg.commission_type === 'percentage' ? 'Porcentual' : dg.commission_type === 'dynamic' ? 'Dinamico' : 'Fijo';
    var dgEarnings = parseFloat(dg.total_earnings || 0).toFixed(2);
    body += `<tr>
      <td>${dg.id}</td>
      <td><strong>${escHtml(dg.name)}</strong></td>
      <td>${escHtml(dg.phone) || '-'}</td>
      <td>${escHtml(dg.vehicle_number) || '-'}</td>
      <td><span class="badge badge-info">${commLabel}</span><br><small class="text-muted">${commType}</small></td>
      <td><strong style="color:#28a745">${typeof currency !== 'undefined' ? currency : '$'}${dgEarnings}</strong></td>
      <td>${statusBadge}</td>
      <td>
        ${approveBtn}
        <a href="/admin/delivery-guy/earnings/${dg.id}" class="btn btn-sm btn-outline-success" title="Ganancias"><i class="fas fa-chart-line"></i></a>
        <button class="btn btn-sm btn-outline-info" data-toggle="modal" data-target="#commModal${dg.id}" title="Comisi\u00f3n"><i class="fas fa-percentage"></i></button>
        <a href="/admin/user/edit/${dg.id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
        <a href="/admin/user/ban/${dg.id}" class="btn btn-sm btn-outline-${dg.is_active !== 0 ? 'danger' : 'success'}"><i class="fas fa-${dg.is_active !== 0 ? 'ban' : 'check'}"></i></a>
      </td>
    </tr>`;
    modalsHtml += `<div class="modal fade" id="commModal${dg.id}" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
      <form method="POST" action="/admin/delivery-guy/commission/save">
        <input type="hidden" name="user_id" value="${dg.id}">
        <div class="modal-header"><h5>Comisi\u00f3n - ${escHtml(dg.name)}</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
        <div class="modal-body">
          <div class="form-group"><label>Tipo de comisi\u00f3n</label><select name="commission_type" class="form-control" id="commType${dg.id}" onchange="var v=this.value;document.getElementById('fixedBlock${dg.id}').style.display=v==='fixed'?'block':'none';document.getElementById('pctBlock${dg.id}').style.display=v==='percentage'?'block':'none';document.getElementById('pctBaseBlock${dg.id}').style.display=v==='percentage'?'block':'none';document.getElementById('dynBlock${dg.id}').style.display=v==='dynamic'?'block':'none'"><option value="fixed" ${dg.commission_type === 'fixed' || (!dg.commission_type) ? 'selected' : ''}>Fijo (monto por pedido)</option><option value="percentage" ${dg.commission_type === 'percentage' ? 'selected' : ''}>Porcentual</option><option value="dynamic" ${dg.commission_type === 'dynamic' ? 'selected' : ''}>Din\u00e1mico (por distancia)</option></select></div>
          <div class="form-group" id="fixedBlock${dg.id}" style="display:${dg.commission_type === 'fixed' || (!dg.commission_type) ? 'block' : 'none'}"><label>Monto fijo por pedido</label><input type="number" step="0.01" name="fixed_commission" class="form-control" value="${dg.fixed_commission || 0}"></div>
          <div class="form-group" id="pctBlock${dg.id}" style="display:${dg.commission_type === 'percentage' ? 'block' : 'none'}"><label>Porcentaje (%)</label><input type="number" step="0.01" name="commission_rate" class="form-control" value="${dg.commission_rate || 0}"></div>
          <div class="form-group" id="pctBaseBlock${dg.id}" style="display:${dg.commission_type === 'percentage' ? 'block' : 'none'}"><label>Porcentaje sobre</label><select name="percentage_base" class="form-control"><option value="total" ${dg.percentage_base !== 'delivery_charge' ? 'selected' : ''}>Monto total del pedido</option><option value="delivery_charge" ${dg.percentage_base === 'delivery_charge' ? 'selected' : ''}>Cargo de delivery</option></select></div>
          <div id="dynBlock${dg.id}" style="display:${dg.commission_type === 'dynamic' ? 'block' : 'none'}">
            <div class="form-group"><label>Distancia Base (km)</label><input type="number" step="0.1" name="dynamic_base_distance" class="form-control" value="${dg.dynamic_base_distance || 0}"></div>
            <div class="form-group"><label>Precio Base</label><input type="number" step="0.01" name="dynamic_base_price" class="form-control" value="${dg.dynamic_base_price || 0}"></div>
            <div class="form-group"><label>Precio por KM extra</label><input type="number" step="0.01" name="dynamic_price_per_km" class="form-control" value="${dg.dynamic_price_per_km || 0}"></div>
          </div>
        </div>
        <div class="modal-footer"><button type="submit" class="btn btn-primary">Guardar</button></div>
      </form>
    </div></div></div>`;
  });
} else {
  body += '<tr><td colspan="8" class="text-center text-muted py-4">No delivery guys found</td></tr>';
}

body += `</tbody></table></div></div></div>
<div id="deliveryGuysModals">${modalsHtml}</div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
