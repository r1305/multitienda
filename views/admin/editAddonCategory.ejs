<% var active = 'addoncategories'; var pageTitle = 'Edit Addon Category'; %>
<% var scripts = ''; %>
<%
var body = '';
if (typeof addonCategory !== 'undefined' && addonCategory) {
  var ac = addonCategory;
  var restaurantOptions = '';
  if (typeof restaurants !== 'undefined') { restaurants.forEach(function(r) { restaurantOptions += '<option value="'+r.id+'" '+(r.id==ac.restaurant_id?'selected':'')+'>'+r.name+'</option>'; }); }

  var addonsHtml = '';
  if (typeof addons !== 'undefined' && addons.length) {
    addons.forEach(function(a) {
      addonsHtml += '<tr><td><strong>'+a.name+'</strong></td><td>$'+parseFloat(a.price).toFixed(2)+'</td><td><span class="badge badge-'+(a.is_active?'success':'danger')+'">'+(a.is_active?'Active':'Inactive')+'</span></td><td><button class="btn btn-sm btn-outline-primary" data-toggle="modal" data-target="#editAddon'+a.id+'"><i class="fas fa-edit"></i></button> <a href="/admin/addon/delete/'+a.id+'" class="btn btn-sm btn-outline-danger" onclick="return confirm(\'Delete?\')"><i class="fas fa-trash"></i></a></td></tr>';
      addonsHtml += '<div class="modal fade" id="editAddon'+a.id+'" tabindex="-1"><div class="modal-dialog"><div class="modal-content"><form method="POST" action="/admin/addon/edit/save"><input type="hidden" name="id" value="'+a.id+'"><input type="hidden" name="addon_category_id" value="'+ac.id+'"><div class="modal-header"><h5>Edit Addon</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div><div class="modal-body"><div class="form-group"><label>Name</label><input type="text" name="name" class="form-control" value="'+a.name+'" required></div><div class="form-group"><label>Price</label><input type="number" step="0.01" name="price" class="form-control" value="'+a.price+'"></div></div><div class="modal-footer"><button type="submit" class="btn btn-primary">Save</button></div></form></div></div></div>';
    });
  } else {
    addonsHtml = '<tr><td colspan="4" class="text-center text-muted py-3">No addons yet</td></tr>';
  }

  body = '<div class="mb-3"><a href="/admin/addon-categories" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left"></i> Back</a></div>' +
  '<div class="row"><div class="col-md-5"><div class="card"><div class="card-header">Addon Category Info</div><div class="card-body">' +
  '<form method="POST" action="/admin/addon-category/edit/save"><input type="hidden" name="id" value="'+ac.id+'">' +
  '<div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" value="'+ac.name+'" required></div>' +
  '<div class="form-group"><label>Type</label><select name="type" class="form-control"><option value="SINGLE" '+(ac.type==='SINGLE'?'selected':'')+'>Single</option><option value="MULTIPLE" '+(ac.type==='MULTIPLE'?'selected':'')+'>Multiple</option></select></div>' +
  '<div class="form-group"><label>Tienda</label><select name="restaurant_id" class="form-control"><option value="">-- Global --</option>'+restaurantOptions+'</select></div>' +
  '<button type="submit" class="btn btn-primary btn-block">Update</button></form></div></div>' +
  '<div class="card mt-3"><div class="card-header">Add New Addon</div><div class="card-body"><form method="POST" action="/admin/addon/new/save"><input type="hidden" name="addon_category_id" value="'+ac.id+'">' +
  '<div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" required></div>' +
  '<div class="form-group"><label>Price</label><input type="number" step="0.01" name="price" class="form-control" value="0"></div>' +
  '<button type="submit" class="btn btn-success btn-block">Add Addon</button></form></div></div></div>' +
  '<div class="col-md-7"><div class="card"><div class="card-header">Addons ('+((typeof addons !== 'undefined') ? addons.length : 0)+')</div><div class="card-body p-0">' +
  '<table class="table table-hover mb-0"><thead><tr><th>Name</th><th>Price</th><th>Status</th><th>Actions</th></tr></thead><tbody>'+addonsHtml+'</tbody></table></div></div></div></div>';
}
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
