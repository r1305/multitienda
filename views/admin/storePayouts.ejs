<% var active = 'payouts'; var pageTitle = 'Store Payouts'; %>
<% var scripts = '<script>$(document).ready(function(){ if($("#payoutsTable tbody tr").length > 1) { $("#payoutsTable").DataTable({order:[[0,"desc"]]}); } });</script>'; %>
<%
var body = `
<div class="card">
    <div class="card-body">
        <table class="table table-hover" id="payoutsTable">
            <thead><tr><th>ID</th><th>Store</th><th>Amount</th><th>Status</th><th>Transaction</th><th>Date</th><th>Actions</th></tr></thead>
            <tbody>`;

if (typeof payouts !== 'undefined' && payouts.length) {
  payouts.forEach(function(p) {
    body += `<tr>
      <td>${p.id}</td>
      <td>${p.restaurant_name || '-'}</td>
      <td>${typeof currency !== 'undefined' ? currency : '$'}${parseFloat(p.amount || 0).toFixed(2)}</td>
      <td><span class="badge badge-${p.status == 'completed' ? 'success' : p.status == 'pending' ? 'warning' : 'secondary'}">${p.status || 'pending'}</span></td>
      <td>${p.transaction_id || '-'}</td>
      <td>${p.created_at ? new Date(p.created_at).toLocaleDateString() : '-'}</td>
      <td><a href="/admin/store-payout/${p.id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a></td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="7" class="text-center text-muted py-4">No payouts found</td></tr>';
}

body += `</tbody></table></div></div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
