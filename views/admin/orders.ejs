<% var active = 'orders'; var pageTitle = 'Orders'; %>
<% var scripts = '<script>$(document).ready(function(){ if($("#ordersTable tbody tr").length > 1) { $("#ordersTable").DataTable({order:[[6,"desc"]]}); } });</script>'; %>
<%
var body = `
<div class="card">
    <div class="card-body">
        <table class="table table-hover" id="ordersTable">
            <thead>
                <tr><th>#ID</th><th>Customer</th><th>Store</th><th>Total</th><th>Status</th><th>Payment</th><th>Date</th><th>Actions</th></tr>
            </thead>
            <tbody>`;

if (typeof orders !== 'undefined' && orders.length) {
  var statusColors = {1:'info',2:'primary',3:'warning',4:'warning',5:'success',6:'danger',7:'secondary',8:'dark',9:'danger',10:'info',11:'primary'};
  var statusNames = {1:'Order Placed',2:'Preparing',3:'Delivery Assigned',4:'Picked Up',5:'Delivered',6:'Canceled',7:'Ready Pickup',8:'Awaiting Payment',9:'Payment Failed',10:'Scheduled',11:'Confirmed'};
  orders.forEach(function(o) {
    body += `<tr>
      <td><strong>${o.unique_order_id}</strong></td>
      <td>${o.user_name || '-'}</td>
      <td>${o.restaurant_name || '-'}</td>
      <td>${typeof currency !== 'undefined' ? currency : '$'}${parseFloat(o.total || 0).toFixed(2)}</td>
      <td><span class="badge badge-${statusColors[o.orderstatus_id] || 'secondary'}">${statusNames[o.orderstatus_id] || 'Unknown'}</span></td>
      <td>${o.payment_mode || 'COD'}</td>
      <td>${o.created_at ? new Date(o.created_at).toLocaleDateString() : '-'}</td>
      <td><a href="/admin/order/${o.unique_order_id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a></td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="8" class="text-center text-muted py-4">No orders found</td></tr>';
}

body += `</tbody></table></div></div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
