<% var active = 'items'; var pageTitle = 'Items'; %>
<% var scripts = '<script>$(document).ready(function(){ if($("#itemsTable tbody tr").length > 1) { $("#itemsTable").DataTable(); } });</script>'; %>
<%
var body = `
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>All Items (${typeof count !== 'undefined' ? count : 0})</span>
        <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newItemModal"><i class="fas fa-plus"></i> Add Item</button>
    </div>
    <div class="card-body">
        <table class="table table-hover" id="itemsTable">
            <thead><tr><th>Image</th><th>Name</th><th>Store</th><th>Category</th><th>Price</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>`;

if (typeof items !== 'undefined' && items.length) {
  items.forEach(function(item) {
    var img = item.image ? `<img src="${item.image}" width="50" height="37" style="object-fit:cover;border-radius:4px">` : '-';
    var oldP = item.old_price > 0 ? ` <small class="text-muted"><del>${typeof currency !== 'undefined' ? currency : '$'}${parseFloat(item.old_price).toFixed(2)}</del></small>` : '';
    body += `<tr>
      <td>${img}</td>
      <td><strong>${item.name}</strong></td>
      <td>${item.restaurant_name || '-'}</td>
      <td>${item.category_name || '-'}</td>
      <td>${typeof currency !== 'undefined' ? currency : '$'}${parseFloat(item.price || 0).toFixed(2)}${oldP}</td>
      <td><span class="badge badge-${item.is_active ? 'success' : 'danger'}">${item.is_active ? 'Active' : 'Inactive'}</span></td>
      <td>
        <a href="/admin/item/edit/${item.id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
        <a href="/admin/item/disable/${item.id}" class="btn btn-sm btn-outline-warning"><i class="fas fa-ban"></i></a>
      </td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="7" class="text-center text-muted py-4">No items found</td></tr>';
}

var restaurantOptions = '';
if (typeof restaurants !== 'undefined') { restaurants.forEach(function(r) { restaurantOptions += `<option value="${r.id}">${r.name}</option>`; }); }
var categoryOptions = '';
if (typeof itemCategories !== 'undefined') { itemCategories.forEach(function(c) { categoryOptions += `<option value="${c.id}">${c.name}</option>`; }); }

body += `</tbody></table></div></div>

<div class="modal fade" id="newItemModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="POST" action="/admin/item/new/save" enctype="multipart/form-data">
                <div class="modal-header"><h5 class="modal-title">Add New Item</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" required></div>
                            <div class="form-group"><label>Store *</label><select name="restaurant_id" class="form-control" required>${restaurantOptions}</select></div>
                            <div class="form-group"><label>Category *</label><select name="item_category_id" class="form-control" required>${categoryOptions}</select></div>
                            <div class="form-group"><label>Image</label><input type="file" name="image" class="form-control-file" accept="image/*"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group"><label>Price *</label><input type="number" step="0.01" name="price" class="form-control" required></div>
                            <div class="form-group"><label>Old Price</label><input type="number" step="0.01" name="old_price" class="form-control" value="0"></div>
                            <div class="form-group"><label>Description</label><textarea name="desc" class="form-control" rows="3"></textarea></div>
                            <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_recommended" value="true"><label class="form-check-label">Recommended</label></div>
                            <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_popular" value="true"><label class="form-check-label">Popular</label></div>
                            <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_new" value="true"><label class="form-check-label">New</label></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-primary">Save Item</button></div>
            </form>
        </div>
    </div>
</div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
