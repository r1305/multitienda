<% var active = 'translations'; var pageTitle = 'Translations'; %>
<% var scripts = ''; %>
<%
var body = `
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Languages (${typeof count !== 'undefined' ? count : 0})</span>
        <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newTransModal"><i class="fas fa-plus"></i> New Language</button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>ID</th><th>Language</th><th>Default</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>`;

if (typeof translations !== 'undefined' && translations.length) {
  translations.forEach(function(t) {
    body += `<tr>
      <td>${t.id}</td>
      <td><strong>${t.language_name}</strong></td>
      <td>${t.is_default ? '<span class="badge badge-success">Default</span>' : '-'}</td>
      <td><span class="badge badge-${t.is_active ? 'success' : 'danger'}">${t.is_active ? 'Active' : 'Inactive'}</span></td>
      <td>
        <a href="/admin/translation/edit/${t.id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
        <a href="/admin/translation/make-default/${t.id}" class="btn btn-sm btn-outline-success" title="Make Default"><i class="fas fa-check"></i></a>
        <a href="/admin/translation/disable/${t.id}" class="btn btn-sm btn-outline-warning"><i class="fas fa-ban"></i></a>
        <a href="/admin/translation/delete/${t.id}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?')"><i class="fas fa-trash"></i></a>
      </td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="5" class="text-center text-muted py-4">No translations found</td></tr>';
}

body += `</tbody></table></div></div>

<div class="modal fade" id="newTransModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="POST" action="/admin/translation/new/save">
                <div class="modal-header"><h5>New Language</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <div class="form-group"><label>Language Name *</label><input type="text" name="language_name" class="form-control" required></div>
                    <div class="form-group"><label>Language Code *</label><input type="text" name="language_code" class="form-control" required placeholder="e.g. en, es, fr"></div>
                    <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_default" value="1"><label class="form-check-label">Set as Default</label></div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-primary">Create</button></div>
            </form>
        </div>
    </div>
</div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
