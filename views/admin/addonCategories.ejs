<% var active = 'addoncategories'; var pageTitle = 'Addon Categories'; %>
<% var scripts = '<script>$(document).ready(function(){ if($("#addonCatTable tbody tr").length > 1) { $("#addonCatTable").DataTable(); } });</script>'; %>
<%
var body = `
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Addon Categories (${typeof count !== 'undefined' ? count : 0})</span>
        <span class="text-muted" style="font-size:12px"><i class="fas fa-info-circle"></i> Addons se gestionan desde el panel del Store Owner</span>
    </div>
    <div class="card-body">
        <table class="table table-hover" id="addonCatTable">
            <thead><tr><th>ID</th><th>Name</th><th>Tienda</th><th>Type</th><th>Addons</th><th>Ver</th></tr></thead>
            <tbody>`;

if (typeof addonCategories !== 'undefined' && addonCategories.length) {
  addonCategories.forEach(function(ac) {
    body += `<tr>
      <td>${ac.id}</td>
      <td><strong>${ac.name}</strong></td>
      <td><small>${ac.restaurant_name || 'Global'}</small></td>
      <td>${ac.type == 'SINGLE' ? 'Single' : 'Multiple'}</td>
      <td>${ac.addons_count || 0}</td>
      <td><a href="/admin/addon-category/edit/${ac.id}" class="btn btn-sm btn-outline-secondary"><i class="fas fa-eye"></i></a></td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="6" class="text-center text-muted py-4">No addon categories found</td></tr>';
}

body += `</tbody></table></div></div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
