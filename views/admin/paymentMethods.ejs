<% var active = 'paymentmethods'; var pageTitle = 'Metodos de Pago'; %>
<% var scripts = ''; %>
<%
var body = `
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Metodos de Pago</span>
        <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newPaymentModal"><i class="fas fa-plus"></i> Nuevo</button>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Nombre</th><th>Nro Cuenta</th><th>Nro Celular</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody>`;

if (typeof gateways !== 'undefined' && gateways.length) {
  gateways.forEach(function(gw) {
    body += `<tr>
      <td><strong>${gw.name}</strong></td>
      <td>${gw.account_number || '-'}</td>
      <td>${gw.phone_number || '-'}</td>
      <td><span class="badge badge-${gw.is_active ? 'success' : 'danger'}">${gw.is_active ? 'Activo' : 'Inactivo'}</span></td>
      <td>
        <button class="btn btn-sm btn-outline-primary" data-toggle="modal" data-target="#editPay${gw.id}"><i class="fas fa-edit"></i></button>
        <a href="/admin/payment-method/toggle/${gw.id}" class="btn btn-sm btn-outline-warning"><i class="fas fa-power-off"></i></a>
        <a href="/admin/payment-method/delete/${gw.id}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Eliminar?')"><i class="fas fa-trash"></i></a>
      </td>
    </tr>
    <div class="modal fade" id="editPay${gw.id}" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
      <form method="POST" action="/admin/payment-method/edit/save">
        <input type="hidden" name="id" value="${gw.id}">
        <div class="modal-header"><h5>Editar Metodo</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
        <div class="modal-body">
          <div class="form-group"><label>Nombre *</label><input type="text" name="name" class="form-control" value="${gw.name}" required></div>
          <div class="form-group"><label>Nro de Cuenta</label><input type="text" name="account_number" class="form-control" value="${gw.account_number || ''}"></div>
          <div class="form-group"><label>Nro de Celular</label><input type="text" name="phone_number" class="form-control" value="${gw.phone_number || ''}"></div>
        </div>
        <div class="modal-footer"><button type="submit" class="btn btn-primary">Guardar</button></div>
      </form>
    </div></div></div>`;
  });
} else {
  body += '<tr><td colspan="5" class="text-center text-muted py-4">Sin metodos de pago</td></tr>';
}

body += `</tbody></table></div></div>

<div class="modal fade" id="newPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="POST" action="/admin/payment-method/new/save">
                <div class="modal-header"><h5>Nuevo Metodo de Pago</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <div class="form-group"><label>Nombre *</label><input type="text" name="name" class="form-control" required placeholder="Ej: Yape, Plin, Transferencia"></div>
                    <div class="form-group"><label>Nro de Cuenta</label><input type="text" name="account_number" class="form-control" placeholder="Opcional"></div>
                    <div class="form-group"><label>Nro de Celular</label><input type="text" name="phone_number" class="form-control" placeholder="Opcional"></div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-primary">Crear</button></div>
            </form>
        </div>
    </div>
</div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
