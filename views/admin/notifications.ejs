<% var active = 'notifications'; var pageTitle = 'Send Notifications'; %>
<% var scripts = ''; %>
<%
var body = `
<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Send Push Notification to All</div>
            <div class="card-body">
                <form method="POST" action="/admin/notifications/send">
                    <div class="form-group"><label>Title *</label><input type="text" name="title" class="form-control" required></div>
                    <div class="form-group"><label>Message *</label><textarea name="message" class="form-control" rows="4" required></textarea></div>
                    <div class="form-group"><label>Image URL (optional)</label><input type="text" name="image" class="form-control"></div>
                    <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-paper-plane"></i> Send to All Users</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Send to Specific Users</div>
            <div class="card-body">
                <form method="POST" action="/admin/notifications/send">
                    <input type="hidden" name="type" value="specific">
                    <div class="form-group"><label>Title *</label><input type="text" name="title" class="form-control" required></div>
                    <div class="form-group"><label>Message *</label><textarea name="message" class="form-control" rows="3" required></textarea></div>
                    <div class="form-group"><label>User IDs (comma separated)</label><input type="text" name="user_ids" class="form-control" placeholder="1,2,3"></div>
                    <button type="submit" class="btn btn-info btn-block"><i class="fas fa-paper-plane"></i> Send to Selected</button>
                </form>
            </div>
        </div>
    </div>
</div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
