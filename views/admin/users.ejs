<% var active = 'users'; var pageTitle = 'Users'; %>
<% var scripts = '<script>$(document).ready(function(){ if($("#usersTable tbody tr").length > 1) { $("#usersTable").DataTable(); } });</script>'; %>
<%
var roleOptions = '';
if (typeof roles !== 'undefined') { roles.forEach(function(r) { roleOptions += `<option value="${r.name}">${r.name}</option>`; }); }

var body = `
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>All Users</span>
        <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newUserModal"><i class="fas fa-plus"></i> Add User</button>
    </div>
    <div class="card-body">
        <table class="table table-hover" id="usersTable">
            <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>`;

if (typeof users !== 'undefined' && users.length) {
  users.forEach(function(u) {
    body += `<tr>
      <td>${u.id}</td>
      <td><strong>${u.name}</strong></td>
      <td>${u.email || '-'}</td>
      <td>${u.phone || '-'}</td>
      <td><span class="badge badge-info">${u.role_name || 'Customer'}</span></td>
      <td><span class="badge badge-${u.is_active !== 0 ? 'success' : 'danger'}">${u.is_active !== 0 ? 'Active' : 'Banned'}</span></td>
      <td>
        <a href="/admin/user/edit/${u.id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
        <a href="/admin/user/ban/${u.id}" class="btn btn-sm btn-outline-${u.is_active !== 0 ? 'danger' : 'success'}"><i class="fas fa-${u.is_active !== 0 ? 'ban' : 'check'}"></i></a>
      </td>
    </tr>`;
  });
} else {
  body += '<tr><td colspan="7" class="text-center text-muted py-4">No users found</td></tr>';
}

body += `</tbody></table></div></div>

<div class="modal fade" id="newUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="POST" action="/admin/user/new/save">
                <div class="modal-header"><h5 class="modal-title">Add New User</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" required></div>
                    <div class="form-group"><label>Email *</label><input type="email" name="email" class="form-control" required></div>
                    <div class="form-group"><label>Phone</label><input type="text" name="phone" class="form-control"></div>
                    <div class="form-group"><label>Password *</label><input type="password" name="password" class="form-control" required></div>
                    <div class="form-group"><label>Role</label><select name="role" class="form-control">${roleOptions}</select></div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-primary">Create User</button></div>
            </form>
        </div>
    </div>
</div>`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
