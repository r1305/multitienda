<% var active = 'stores'; var pageTitle = 'Edit Store - ' + (typeof restaurant !== 'undefined' && restaurant ? restaurant.name : ''); %>
<% var scripts = ''; %>
<%
var body = '';
if (typeof restaurant !== 'undefined' && restaurant) {
  var r = restaurant;
  body = `
  <form method="POST" action="/admin/store/edit/save" enctype="multipart/form-data">
    <input type="hidden" name="id" value="${r.id}">
    <input type="hidden" name="old_image" value="${r.image || ''}">
    <div class="row">
      <div class="col-md-8">
        <div class="card"><div class="card-header">Store Information</div><div class="card-body"><div class="row">
          <div class="col-md-6">
            <div class="form-group"><label>Name *</label><input type="text" name="name" class="form-control" value="${r.name}" required></div>
            <div class="form-group"><label>Description</label><textarea name="description" class="form-control" rows="3">${r.description || ''}</textarea></div>
            <div class="form-group"><label>Image</label><input type="file" name="image" class="form-control-file" accept="image/*">${r.image ? `<img src="${r.image}" width="80" class="mt-2">` : ''}</div>
            <div class="form-group"><label>Address</label><input type="text" name="address" class="form-control" value="${r.address || ''}"></div>
            <div class="form-group"><label>Pincode</label><input type="text" name="pincode" class="form-control" value="${r.pincode || ''}"></div>
            <div class="form-group"><label>Landmark</label><input type="text" name="landmark" class="form-control" value="${r.landmark || ''}"></div>
          </div>
          <div class="col-md-6">
            <div class="form-group"><label>Latitude</label><input type="text" name="latitude" class="form-control" value="${r.latitude || ''}"></div>
            <div class="form-group"><label>Longitude</label><input type="text" name="longitude" class="form-control" value="${r.longitude || ''}"></div>
            <div class="form-group"><label>Certificate</label><input type="text" name="certificate" class="form-control" value="${r.certificate || ''}"></div>
            <div class="form-group"><label>Rating</label><input type="text" name="rating" class="form-control" value="${r.rating || ''}"></div>
            <div class="form-group"><label>Delivery Time</label><input type="text" name="delivery_time" class="form-control" value="${r.delivery_time || ''}"></div>
            <div class="form-group"><label>Price Range</label><input type="text" name="price_range" class="form-control" value="${r.price_range || ''}"></div>
          </div>
        </div></div></div>
        <div class="card"><div class="card-header">Charges & Delivery</div><div class="card-body"><div class="row">
          <div class="col-md-4"><div class="form-group"><label>Restaurant Charges</label><input type="number" step="0.01" name="restaurant_charges" class="form-control" value="${r.restaurant_charges || 0}"></div></div>
          <div class="col-md-4"><div class="form-group"><label>Delivery Charges</label><input type="number" step="0.01" name="delivery_charges" class="form-control" value="${r.delivery_charges || 0}"></div></div>
          <div class="col-md-4"><div class="form-group"><label>Commission Rate (%)</label><input type="number" step="0.01" name="commission_rate" class="form-control" value="${r.commission_rate || 0}"></div></div>
        </div><div class="row">
          <div class="col-md-4"><div class="form-group"><label>Delivery Type</label><select name="delivery_type" class="form-control"><option value="1" ${r.delivery_type==1?'selected':''}>Delivery</option><option value="2" ${r.delivery_type==2?'selected':''}>Self Pickup</option><option value="3" ${r.delivery_type==3?'selected':''}>Both</option></select></div></div>
          <div class="col-md-4"><div class="form-group"><label>Delivery Radius (km)</label><input type="number" step="0.1" name="delivery_radius" class="form-control" value="${r.delivery_radius || ''}"></div></div>
          <div class="col-md-4"><div class="form-group"><label>Min Order Price</label><input type="number" step="0.01" name="min_order_price" class="form-control" value="${r.min_order_price || 0}"></div></div>
        </div></div></div>
      </div>
      <div class="col-md-4">
        <div class="card"><div class="card-header">Options</div><div class="card-body">
          <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_pureveg" value="true" ${r.is_pureveg ? 'checked' : ''}><label class="form-check-label">Pure Veg</label></div>
          <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_featured" value="true" ${r.is_featured ? 'checked' : ''}><label class="form-check-label">Featured</label></div>
          <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_schedulable" value="true" ${r.is_schedulable ? 'checked' : ''}><label class="form-check-label">Schedulable</label></div>
          <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="auto_acceptable" value="true" ${r.auto_acceptable ? 'checked' : ''}><label class="form-check-label">Auto Accept Orders</label></div>
          <div class="form-check mb-2"><input type="checkbox" class="form-check-input" name="is_notifiable" value="true" ${r.is_notifiable ? 'checked' : ''}><label class="form-check-label">SMS Notifiable</label></div>
        </div></div>
        <button type="submit" class="btn btn-primary btn-block btn-lg"><i class="fas fa-save"></i> Update Store</button>
      </div>
    </div>
  </form>`;
}
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts }) %>
