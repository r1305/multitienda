            ${d.active_orders > 0 ? '<span class="badge badge-warning">'+d.active_orders+' en ruta</span>' : (d.is_online ? '<span class="badge badge-success">En línea</span>' : '<span class="badge badge-secondary">Sin GPS</span>')}
