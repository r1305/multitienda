      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card orange">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
        <div><h5 class="mb-0" style="font-weight:700">${typeof stats !== 'undefined' ? stats.pendingOrders : 0}</h5><small class="text-muted">Pendientes</small></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card green">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
        <div><h5 class="mb-0" style="font-weight:700">${typeof stats !== 'undefined' ? stats.completedOrders : 0}</h5><small class="text-muted">Completados</small></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card red">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="stat-icon red"><i class="fas fa-times-circle"></i></div>
        <div><h5 class="mb-0" style="font-weight:700">${typeof stats !== 'undefined' ? stats.cancelledOrders : 0}</h5><small class="text-muted">Cancelados</small></div>
      </div>
    </div>
  </div>
</div>

<!-- Platform Stats -->
<div class="row mb-3">
  <div class="col-4">
    <div class="card stat-card teal">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="stat-icon teal"><i class="fas fa-users"></i></div>
        <div><h5 class="mb-0" style="font-weight:700">${typeof stats !== 'undefined' ? stats.totalUsers : 0}</h5><small class="text-muted">Usuarios</small></div>
      </div>
    </div>
  </div>
  <div class="col-4">
    <div class="card stat-card orange">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="stat-icon orange"><i class="fas fa-store"></i></div>
        <div><h5 class="mb-0" style="font-weight:700">${typeof stats !== 'undefined' ? stats.totalStores : 0}</h5><small class="text-muted">Tiendas</small></div>
      </div>
    </div>
  </div>
  <div class="col-4">
    <div class="card stat-card blue">
      <div class="card-body d-flex align-items-center gap-3 py-3">
        <div class="stat-icon blue"><i class="fas fa-motorcycle"></i></div>
        <div><h5 class="mb-0" style="font-weight:700">${typeof stats !== 'undefined' ? stats.totalDelivery : 0}</h5><small class="text-muted">Repartidores</small></div>
      </div>
    </div>
  </div>
</div>

<!-- Earnings Chart -->
<div class="card mb-3">
  <div class="card-header d-flex justify-content-between align-items-center flex-wrap" style="gap:8px">
    <div>
      <i class="fas fa-chart-line text-primary mr-1"></i>
      <span style="font-weight:600">Ganancias</span>
      <span id="totalEarnings" class="ml-2 badge badge-primary" style="font-size:12px">${currency}0.00</span>
    </div>
    <div class="d-flex flex-wrap" style="gap:6px">
      <button class="btn btn-sm btn-outline-primary filter-btn active" data-filter="week" onclick="loadChart('week')">7d</button>
      <button class="btn btn-sm btn-outline-primary filter-btn" data-filter="month" onclick="loadChart('month')">30d</button>
      <button class="btn btn-sm btn-outline-primary filter-btn" data-filter="custom" onclick="loadChart('custom')">Rango</button>
    </div>
  </div>
  <div class="card-body">
    <div id="customRange" style="display:none;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center">
      <input type="date" id="dateFrom" class="form-control form-control-sm" style="width:auto">
