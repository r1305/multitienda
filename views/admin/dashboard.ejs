      </div>
    </div>
  </div>
</div>
`;
%>
<%- include('./layouts/master', { body, active, pageTitle, user: typeof user !== 'undefined' ? user : null, success: typeof success !== 'undefined' ? success : null, error: typeof error !== 'undefined' ? error : null, message: typeof message !== 'undefined' ? message : null, scripts, settings: typeof settings !== 'undefined' ? settings : {} }) %>
