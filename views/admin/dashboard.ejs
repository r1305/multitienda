      </div>
    </div>
  </div>
</div>

<!-- Stats Grid -->
<div class="row mb-3">
  <div class="col-6 col-lg-3">
    <div class="card stat-card blue">
      <div class="card-body d-flex align-items-center gap-3 py-3">
