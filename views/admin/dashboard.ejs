<% var active = 'dashboard'; var pageTitle = 'Dashboard'; %>
<%
var currency = typeof settings !== 'undefined' && settings && settings.currencySymbol ? settings.currencySymbol : '$';
var elapsedFn = typeof formatOrderElapsed === 'function' ? formatOrderElapsed : function() { return '-'; };

var scripts = `
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
let earningsChart = null;

function loadChart(filter) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('[data-filter="'+filter+'"]').classList.add('active');
  const customEl = document.getElementById('customRange');
  if (filter === 'custom') {
    customEl.style.display = 'flex';
    if (!document.getElementById('dateFrom').value) document.getElementById('dateFrom').value = new Date().toISOString().split('T')[0];
    if (!document.getElementById('dateTo').value) document.getElementById('dateTo').value = new Date().toISOString().split('T')[0];
  } else { customEl.style.display = 'none'; }

  let url = '/admin/api/earnings-chart?filter=' + filter;
  if (filter === 'custom') {
    const from = document.getElementById('dateFrom').value;
    const to = document.getElementById('dateTo').value;
    if (!from || !to) return;
    url += '&from=' + from + '&to=' + to;
  }

  fetch(url).then(r => r.json()).then(data => {
    const ctx = document.getElementById('earningsChart').getContext('2d');
    if (earningsChart) earningsChart.destroy();
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const gridColor = isDark ? 'rgba(255,255,255,.08)' : 'rgba(0,0,0,.06)';
    const textColor = isDark ? '#aaa' : '#666';
    earningsChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: data.labels,
        datasets: [{
          label: 'Ganancias',
          data: data.values,
          borderColor: '#007bff',
          backgroundColor: 'rgba(0,123,255,.08)',
          fill: true,
          tension: 0.4,
          pointRadius: 3,
          pointBackgroundColor: '#007bff',
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 600 },
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, grid: { color: gridColor }, ticks: { color: textColor, callback: v => '${currency}' + v } },
          x: { grid: { display: false }, ticks: { color: textColor } }
        }
      }
    });
    document.getElementById('totalEarnings').textContent = '${currency}' + data.total.toFixed(2);
  });
}

document.addEventListener('DOMContentLoaded', function() { loadChart('week'); refreshOrderElapsedCells(); setInterval(refreshOrderElapsedCells, 30000); });

window.formatOrderElapsed = function(createdAt, statusId, updatedAt) {
  if (!createdAt) return '-';
  var start = new Date(createdAt).getTime();
  if (isNaN(start)) return '-';
  var sid = parseInt(statusId, 10);
  var end = Date.now();
  if ((sid === 5 || sid === 6) && updatedAt) {
    var u = new Date(updatedAt).getTime();
    if (!isNaN(u)) end = u;
  }
  var ms = Math.max(0, end - start);
  var mins = Math.floor(ms / 60000);
  if (mins < 1) return '< 1 min';
  if (mins < 60) return mins + ' min';
  var hours = Math.floor(mins / 60), rm = mins % 60;
  if (hours < 24) return rm ? hours + ' h ' + rm + ' min' : hours + ' h';
  var days = Math.floor(hours / 24), rh = hours % 24;
  return rh ? days + ' d ' + rh + ' h' : days + ' d';
};
function refreshOrderElapsedCells() {
  document.querySelectorAll('[data-order-elapsed]').forEach(function(el) {
    el.textContent = formatOrderElapsed(el.dataset.created, el.dataset.status, el.dataset.updated || '');
  });
}

function statusBadge(id) {
  const map = {1:'info',2:'warning',3:'warning',4:'warning',5:'success',6:'danger',7:'success',8:'secondary',9:'danger',10:'purple',11:'info'};
  return map[id] || 'secondary';
}
function statusText(id) {
  const map = {1:'Nuevo',2:'Preparando',3:'En delivery',4:'En camino',5:'Entregado',6:'Cancelado',7:'Listo',8:'Pago pend.',9:'Pago fallido',10:'Programado',11:'Confirmado'};
  return map[id] || '-';
}
</script>
<style>
.stat-card { border-left: 4px solid; transition: transform .15s; }
.stat-card:hover { transform: translateY(-2px); }
.stat-card .card-body { gap: 14px !important; }
.stat-card.blue { border-left-color: #007bff; }
.stat-card.green { border-left-color: #28a745; }
.stat-card.orange { border-left-color: #fd7e14; }
.stat-card.red { border-left-color: #dc3545; }
.stat-card.purple { border-left-color: #6f42c1; }
.stat-card.teal { border-left-color: #20c997; }
.stat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.stat-icon.blue { background: rgba(0,123,255,.1); color: #007bff; }
.stat-icon.green { background: rgba(40,167,69,.1); color: #28a745; }
.stat-icon.orange { background: rgba(253,126,20,.1); color: #fd7e14; }
.stat-icon.red { background: rgba(220,53,69,.1); color: #dc3545; }
.stat-icon.purple { background: rgba(111,66,193,.1); color: #6f42c1; }
.stat-icon.teal { background: rgba(32,201,151,.1); color: #20c997; }
.quick-link { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 16px 8px; border-radius: 10px; text-decoration: none; color: inherit; transition: background .15s; font-size: 12px; font-weight: 500; text-align: center; }
.quick-link:hover { background: rgba(0,123,255,.06); text-decoration: none; color: inherit; }
.quick-link i { font-size: 22px; color: var(--primary); }
[data-theme="dark"] .quick-link:hover { background: rgba(255,255,255,.05); }
[data-theme="dark"] .stat-icon.blue { background: rgba(0,123,255,.15); }
[data-theme="dark"] .stat-icon.green { background: rgba(40,167,69,.15); }
[data-theme="dark"] .stat-icon.orange { background: rgba(253,126,20,.15); }
[data-theme="dark"] .stat-icon.red { background: rgba(220,53,69,.15); }
[data-theme="dark"] .stat-icon.purple { background: rgba(111,66,193,.15); }
[data-theme="dark"] .stat-icon.teal { background: rgba(32,201,151,.15); }
.badge-purple { background: #6f42c1; color: #fff; }
</style>`;

var body = `
<!-- Welcome & Today Summary -->
