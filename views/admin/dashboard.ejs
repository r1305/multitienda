        <div class="stat-icon green"><i class="fas fa-dollar-sign"></i></div>
        <div><h4 class="mb-0" style="font-size:20px;font-weight:700">${currency} ${typeof stats !== 'undefined' ? parseFloat(stats.todayRevenue).toFixed(2) : '0.00'}</h4><small class="text-muted">Ingresos hoy</small></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card purple">
      <div class="card-body d-flex align-items-center gap-3 py-3">
