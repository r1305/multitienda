      <canvas id="earningsChart"></canvas>
    </div>
  </div>
</div>

<!-- Quick Links -->
<div class="card mb-3">
  <div class="card-header"><i class="fas fa-bolt mr-1" style="color:#fd7e14"></i> Accesos rápidos</div>
  <div class="card-body" style="padding:12px">
    <div class="row">
      <div class="col-4 col-md-2"><a href="/admin/orders" class="quick-link"><i class="fas fa-receipt"></i>Pedidos</a></div>
      <div class="col-4 col-md-2"><a href="/admin/stores" class="quick-link"><i class="fas fa-store"></i>Tiendas</a></div>
      <div class="col-4 col-md-2"><a href="/admin/items" class="quick-link"><i class="fas fa-utensils"></i>Items</a></div>
      <div class="col-4 col-md-2"><a href="/admin/delivery-guys" class="quick-link"><i class="fas fa-motorcycle"></i>Delivery</a></div>
      <div class="col-4 col-md-2"><a href="/admin/coupons" class="quick-link"><i class="fas fa-ticket-alt"></i>Cupones</a></div>
      <div class="col-4 col-md-2"><a href="/admin/settings" class="quick-link"><i class="fas fa-cog"></i>Settings</a></div>
    </div>
  </div>
</div>

<div class="row">
  <!-- Recent Orders -->
  <div class="col-lg-7 mb-3">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-receipt mr-1 text-primary"></i> Últimos pedidos</span>
        <a href="/admin/orders" class="btn btn-sm btn-outline-primary">Ver todos</a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead><tr><th>#</th><th>Cliente</th><th>Tienda</th><th>Total</th><th>Estado</th><th>Tiempo</th><th>Fecha</th></tr></thead>
            <tbody>
              ${(typeof recentOrders !== 'undefined' ? recentOrders : []).map(o => {
                const elapsed = elapsedFn(o.created_at, o.orderstatus_id, o.updated_at);
                const orderUrl = o.unique_order_id || o.id;
                return `
              <tr style="cursor:pointer" onclick="location.href='/admin/order/${orderUrl}'">
                <td><strong>${o.unique_order_id || o.id}</strong></td>
                <td>${o.user_name || '-'}</td>
                <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${o.restaurant_name || '-'}</td>
                <td><strong>${currency}${parseFloat(o.total||0).toFixed(2)}</strong></td>
                <td><span class="badge badge-${({1:'info',2:'warning',3:'warning',4:'warning',5:'success',6:'danger',7:'success',8:'secondary',10:'purple',11:'info'})[o.orderstatus_id]||'secondary'}">${({1:'Nuevo',2:'Preparando',3:'En delivery',4:'En camino',5:'Entregado',6:'Cancelado',7:'Listo',8:'Pago pend.',10:'Programado',11:'Confirmado'})[o.orderstatus_id]||'-'}</span></td>
                <td><span class="text-nowrap" style="font-size:12px" data-order-elapsed data-created="${o.created_at || ''}" data-status="${o.orderstatus_id}" data-updated="${o.updated_at || ''}">${elapsed}</span></td>
                <td style="font-size:11px;color:#888">${new Date(o.created_at).toLocaleDateString('es',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</td>
              </tr>`;
              }).join('')}
              ${(typeof recentOrders === 'undefined' || !recentOrders.length) ? '<tr><td colspan="7" class="text-center text-muted py-4">Sin pedidos</td></tr>' : ''}
            </tbody>
          </table>
        </div>
      </div>
