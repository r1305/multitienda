# Firebase Messaging service worker — must return JavaScript, not SPA index.html
<IfModule mod_headers.c>
  <FilesMatch "(?i)^firebase-messaging-sw\.js$">
    Header set Content-Type "application/javascript; charset=utf-8"
    Header set Service-Worker-Allowed "/"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^firebase-messaging-sw\.js$ - [L,NC]
</IfModule>
